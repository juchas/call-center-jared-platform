# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ccjplatform

# Koyeb
KOYEB_TOKEN=your_koyeb_api_token_here
KOYEB_APP_ID=your_koyeb_app_id_here

# Encryption key for tenant credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your_fernet_key_here

# Optional: restrict API access
API_SECRET_KEY=

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
